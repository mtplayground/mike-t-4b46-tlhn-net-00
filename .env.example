# Copy this file to .env for local development. Keep real secrets out of git.

# PostgreSQL connection string. Production receives this from zeroclaw/Fly MPG.
DATABASE_URL=postgres://tlhn_user:tlhn_password@localhost:5432/tlhn

# Rust Axum server bind address.
HOST=0.0.0.0
PORT=8080

# Runtime feature timing.
POLLING_INTERVAL_MS=5000
COUNTDOWN_DEADLINE_ISO=2029-12-01T07:00:00.000Z

# Ideavibes platform auth. Production receives these from zeroclaw.
SELF_URL=http://localhost:8080
MCTAI_AUTH_URL=https://auth.mctai.app
MCTAI_AUTH_APP_TOKEN=app_mike-t-4b46-tlhn-net-00-aa894f
MCTAI_AUTH_JWKS_URL=https://auth.mctai.app/.well-known/jwks.json


# Vite exposes only VITE_* variables to browser code at build/dev time.
VITE_POLLING_INTERVAL_MS=5000
VITE_COUNTDOWN_DEADLINE_ISO=2029-12-01T07:00:00.000Z
